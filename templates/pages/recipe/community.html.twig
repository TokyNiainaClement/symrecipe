{% extends 'base.html.twig' %}

{% block title %}
	SymRecipe - Recette de la communauté
{% endblock %}

{% block body %}

	<h1 class="text-2xl font-bold text-[#3b3a30] mb-8">Recettes de la communauté</h1>

	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
		{% for recipe in recipes %}
			<div class="rounded-xl border border-[#3b3a30]/20 overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200">

				<div class="bg-[#3b3a30] text-[#ffcc5c] text-xs font-semibold uppercase tracking-widest px-4 py-2.5">
					Recette n°{{ recipe.id }}
				</div>

				<div class="bg-white p-5 flex flex-col gap-2">
					<a href="{{ path('recipe.show', {id: recipe.id}) }}"
					   class="font-semibold text-[#3b3a30] hover:text-[#ffcc5c] transition leading-snug">
						{{ recipe.name }}
					</a>
					<p class="text-sm text-black/60 leading-relaxed">
						{{ recipe.description|slice(0, 100) ~ '...' }}
					</p>
				</div>

			</div>
		{% endfor %}
	</div>

	<!-- Pagination -->
	<div class="flex justify-center">
		{{ knp_pagination_render(recipes) }}
	</div>

{% endblock %}