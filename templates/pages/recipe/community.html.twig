{% extends 'base.html.twig' %}

{% block title %}
	SymRecipe - Recette de la communauté
{% endblock %}

{% block body %}

	<h1 class="text-3xl font-bold text-[#3b3a30] mb-8">Recettes de la communauté</h1>

	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
		{% for recipe in recipes %}
			<div
				class="rounded-xl border border-[#3b3a30]/20 overflow-visible shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200 flex flex-col">

				<!-- Badge avec image arrondie qui dépasse -->
				<div class="bg-[#3b3a30] px-4 pt-4 pb-3 flex items-center gap-4 rounded-t-xl">
					{% if vich_uploader_asset(recipe, 'imageFile') %}
						<img src="{{ vich_uploader_asset(recipe, 'imageFile') }}" alt="{{ recipe.name }}" class="w-16 h-16 rounded-full object-cover border-4 border-[#ffcc5c] shadow-lg shrink-0 -mt-6">
					{% else %}
						<span class="w-16 h-16 rounded-full bg-[#ffcc5c]/20 border-4 border-[#ffcc5c]/50 flex items-center justify-center text-2xl shrink-0 -mt-6">
							🍽️
						</span>
					{% endif %}
					<span class="text-[#ffcc5c] text-xs font-semibold uppercase tracking-widest">
						Recette n°{{ recipe.id }}
					</span>
				</div>

				<!-- Contenu -->
				<div class="bg-white p-5 flex flex-col gap-2 flex-1 rounded-b-xl">
					<a href="{{ path('recipe.show', {id: recipe.id}) }}" class="font-semibold text-[#3b3a30] hover:text-[#ffcc5c] transition leading-snug">
						{{ recipe.name }}
					</a>
					<p class="text-sm text-black/60 leading-relaxed">
						{{ recipe.description|slice(0, 100) ~ '...' }}
					</p>
				</div>

			</div>
		{% endfor %}
	</div>

	<!-- Pagination -->
	<div class="flex justify-center">
		{{ knp_pagination_render(recipes) }}
	</div>

{% endblock %}
