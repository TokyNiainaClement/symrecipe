{% extends 'base.html.twig' %}

{% block title %}Symrecipe - Mes recettes
{% endblock %}

{% block body %}
	<div class="container mt-4">

		{% if not recipes.items is same as([]) %}
			<h1>Mes recettes</h1>

			{# affiche un message de succes #}
			{% for message in app.flashes('success') %}
				<div class="alert alert-success mt-3">
					<strong>Succès!</strong>
					{{ message }}
				</div>
			{% endfor %}

			{# affiche le nombre total d'ingrédient #}
			<div class="count mt-4">
				Il y a
				{{ recipes.getTotalItemCount }}
				recettes au total
			</div>

			{# Afficher la liste des recettes #}
			<table class="table table-bordered table-borderless">
				<thead>
					<tr>
						<th>Numréro</th>
						<th>Nom</th>
						<th>Prix</th>
						<th>Difficulté</th>
						<th>Date de création</th>
						<th colspan="2">Action</th>
					</tr>
				</thead>
				<tbody>
					{% for recipe in recipes %}
						<tr class="table-active">
							<td>{{ recipe.id }}</td>
							<td>{{ recipe.name }}</td>
							<td>{{ (recipe.price is same as(null)) ? '--' : recipe.price}}</td>
							<td>{{ (recipe.difficulty is same as(null)) ? '--' : recipe.difficulty}}</td>
							<td>{{ recipe.createdAt|date('d/m/Y') }}</td>
							<td>
								<a class="btn btn-info btn-sm" href="{{ path('recipe.edit', {id: recipe.id}) }}">
									Modifier
								</a>
							</td>
							<td>
								<a class="btn btn-danger btn-sm" href="{{ path('recipe.delete', {id: recipe.id}) }}">
									Supprimer
								</a>
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>

			{# affiche la navigation de pagination #}
			<div class="navigation d-flex justify-content-center">
				{{ knp_pagination_render(recipes) }}
			</div>

		{% else %}
			<h4>Il n'y a pas de recette</h4>
		{% endif %}

		<a class="btn btn-dark btn-sm mt-3" href="{{ path('recipe.new') }}">
			Créer une recette
		</a>

	</div>
{% endblock %}
