{% extends 'base.html.twig' %}

{% block title %}Symrecipe - Mes recettes
{% endblock %}

{% block body %}

	{% if not recipes.items is same as([]) %}

		<!-- En-tête -->
		<div class="flex items-center justify-between mb-6">
			<h1 class="text-2xl font-bold text-[#3b3a30]">Mes recettes</h1>
			<a href="{{ path('recipe.new') }}"
			   class="inline-block px-5 py-2 rounded-full bg-[#3b3a30] text-white text-sm font-semibold
			          hover:bg-[#ffcc5c] hover:text-[#3b3a30] transition shadow-md">
				+ Créer une recette
			</a>
		</div>

		<!-- Flash success -->
		{% for message in app.flashes('success') %}
			<div class="flex items-center gap-3 bg-green-50 border border-green-200 text-green-800 text-sm rounded-lg px-4 py-3 mb-5">
				<span class="font-semibold">Succès !</span>
				{{ message }}
			</div>
		{% endfor %}

		<!-- Compteur -->
		<p class="text-sm text-black/50 mb-4">
			Il y a <span class="font-semibold text-[#3b3a30]">{{ recipes.getTotalItemCount }}</span> recette(s) au total
		</p>

		<!-- Table -->
		<div class="rounded-xl border border-[#3b3a30]/20 overflow-hidden shadow-sm mb-6">
			<table class="w-full text-sm">
				<thead>
					<tr class="bg-[#3b3a30] text-[#ffcc5c] text-xs uppercase tracking-widest">
						<th class="px-4 py-3 text-left font-semibold">Numéro</th>
						<th class="px-4 py-3 text-left font-semibold">Nom</th>
						<th class="px-4 py-3 text-left font-semibold">Prix</th>
						<th class="px-4 py-3 text-left font-semibold">Difficulté</th>
						<th class="px-4 py-3 text-left font-semibold">Date de création</th>
						<th class="px-4 py-3 text-center font-semibold" colspan="2">Actions</th>
					</tr>
				</thead>
				<tbody>
					{% for recipe in recipes %}
						<tr class="border-t border-[#3b3a30]/10 hover:bg-[#ffcc5c]/5 transition">
							<td class="px-4 py-3 text-black/50 font-mono text-xs">#{{ recipe.id }}</td>
							<td class="px-4 py-3 font-medium text-[#3b3a30]">{{ recipe.name }}</td>
							<td class="px-4 py-3 text-black/70">
								{{ (recipe.price is same as(null)) ? '--' : recipe.price|number_format(2, '.', ',') ~ ' €' }}
							</td>
							<td class="px-4 py-3 text-black/70">
								{{ (recipe.difficulty is same as(null)) ? '--' : recipe.difficulty }}
							</td>
							<td class="px-4 py-3 text-black/50">{{ recipe.createdAt|date('d/m/Y') }}</td>
							<td class="px-4 py-3 text-center">
								<a href="{{ path('recipe.edit', {id: recipe.id}) }}"
								   class="inline-block px-3 py-1 rounded-full text-xs font-semibold
								          bg-[#3b3a30] text-white hover:bg-[#ffcc5c] hover:text-[#3b3a30] transition">
									Modifier
								</a>
							</td>
							<td class="px-4 py-3 text-center">
								<a href="{{ path('recipe.delete', {id: recipe.id}) }}"
								   class="inline-block px-3 py-1 rounded-full text-xs font-semibold
								          bg-red-100 text-red-600 hover:bg-red-500 hover:text-white transition">
									Supprimer
								</a>
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>

		<!-- Pagination -->
		<div class="flex justify-center">
			{{ knp_pagination_render(recipes) }}
		</div>

	{% else %}

		<!-- État vide -->
		<div class="flex flex-col items-center justify-center py-20 text-center">
			<p class="text-2xl font-semibold text-[#3b3a30] mb-2">Aucune recette</p>
			<p class="text-black/50 text-sm mb-6">Commencez par créer votre première recette.</p>
			<a href="{{ path('recipe.new') }}"
			   class="inline-block px-6 py-2.5 rounded-full bg-[#3b3a30] text-white text-sm font-semibold
			          hover:bg-[#ffcc5c] hover:text-[#3b3a30] transition shadow-md">
				+ Créer une recette
			</a>
		</div>

	{% endif %}

{% endblock %}