{% extends 'base.html.twig' %}

{% block title %}Symrecipe - Modifier la recette
{% endblock %}

{% block body %}

	<div class="max-w-2xl mx-auto">

		<h1 class="text-2xl font-bold text-[#3b3a30] mb-8">Modification de la recette</h1>

		<form name="recipe" method="post"
		      class="bg-white border border-[#3b3a30]/20 rounded-2xl shadow-sm p-8 flex flex-col gap-6">

			<div class="flex flex-col gap-1.5">
				{{ form_label(form.name, null, {label_attr: {class: 'text-sm font-semibold text-[#3b3a30]'}}) }}
				{{ form_widget(form.name, {attr: {class: 'w-full border border-[#3b3a30]/30 rounded-lg px-4 py-2.5 text-sm text-black focus:outline-none focus:border-[#ffcc5c] focus:ring-2 focus:ring-[#ffcc5c]/30 transition'}}) }}
				{{ form_errors(form.name) }}
			</div>

			<div class="flex flex-col gap-1.5">
				{{ form_label(form.time, null, {label_attr: {class: 'text-sm font-semibold text-[#3b3a30]'}}) }}
				{{ form_widget(form.time, {attr: {class: 'w-full border border-[#3b3a30]/30 rounded-lg px-4 py-2.5 text-sm text-black focus:outline-none focus:border-[#ffcc5c] focus:ring-2 focus:ring-[#ffcc5c]/30 transition'}}) }}
				{{ form_errors(form.time) }}
			</div>

			<div class="grid grid-cols-2 gap-4">
				<div class="flex flex-col gap-1.5">
					{{ form_label(form.nbPeople, null, {label_attr: {class: 'text-sm font-semibold text-[#3b3a30]'}}) }}
					{{ form_widget(form.nbPeople, {attr: {class: 'w-full border border-[#3b3a30]/30 rounded-lg px-4 py-2.5 text-sm text-black focus:outline-none focus:border-[#ffcc5c] focus:ring-2 focus:ring-[#ffcc5c]/30 transition'}}) }}
					{{ form_errors(form.nbPeople) }}
				</div>

				<div class="flex flex-col gap-1.5">
					{{ form_label(form.difficulty, null, {label_attr: {class: 'text-sm font-semibold text-[#3b3a30]'}}) }}
					{{ form_widget(form.difficulty, {attr: {class: 'w-full border border-[#3b3a30]/30 rounded-lg px-4 py-2.5 text-sm text-black focus:outline-none focus:border-[#ffcc5c] focus:ring-2 focus:ring-[#ffcc5c]/30 transition'}}) }}
					{{ form_errors(form.difficulty) }}
				</div>
			</div>

			<div class="flex flex-col gap-1.5">
				{{ form_label(form.description, null, {label_attr: {class: 'text-sm font-semibold text-[#3b3a30]'}}) }}
				{{ form_widget(form.description, {attr: {class: 'w-full border border-[#3b3a30]/30 rounded-lg px-4 py-2.5 text-sm text-black focus:outline-none focus:border-[#ffcc5c] focus:ring-2 focus:ring-[#ffcc5c]/30 transition resize-none', 'rows': 4}}) }}
				{{ form_errors(form.description) }}
			</div>

			<div class="flex flex-col gap-1.5">
				{{ form_label(form.price, null, {label_attr: {class: 'text-sm font-semibold text-[#3b3a30]'}}) }}
				{{ form_widget(form.price, {attr: {class: 'w-full border border-[#3b3a30]/30 rounded-lg px-4 py-2.5 text-sm text-black focus:outline-none focus:border-[#ffcc5c] focus:ring-2 focus:ring-[#ffcc5c]/30 transition'}}) }}
				{{ form_errors(form.price) }}
			</div>

			<div class="flex items-center gap-3">
				{{ form_widget(form.isFavorite, {attr: {class: 'w-4 h-4 accent-[#ffcc5c] cursor-pointer'}}) }}
				<label class="text-sm font-medium text-[#3b3a30] cursor-pointer">Favorite ?</label>
				{{ form_errors(form.isFavorite) }}
			</div>

			<div class="flex flex-col gap-1.5">
				{{ form_label(form.ingredients, null, {label_attr: {class: 'text-sm font-semibold text-[#3b3a30]'}}) }}
				{{ form_widget(form.ingredients, {attr: {class: 'w-full border border-[#3b3a30]/30 rounded-lg px-4 py-2.5 text-sm text-black focus:outline-none focus:border-[#ffcc5c] focus:ring-2 focus:ring-[#ffcc5c]/30 transition'}}) }}
				{{ form_errors(form.ingredients) }}
			</div>

			{{ form_row(form._token) }}

			<div class="flex items-center gap-4 pt-2">
				<button type="submit" id="recipe_submit" name="recipe[submit]"
				        class="px-6 py-2.5 rounded-full bg-[#3b3a30] text-white text-sm font-semibold
				               hover:bg-[#ffcc5c] hover:text-[#3b3a30] transition shadow-md cursor-pointer">
					Mettre à jour cette recette
				</button>
				<a href="{{ path('recipe.index') }}"
				   class="text-sm text-black/50 hover:text-[#3b3a30] transition">
					Annuler
				</a>
			</div>

		</form>

	</div>

{% endblock %}