{% extends 'base.html.twig' %}

{% block title %}
	SymRecipe - Information sur la recette
	{{ recipe.name }}
{% endblock %}

{% block body %}

	<!-- Flash success -->
	{% for message in app.flashes('success') %}
		<div class="flex items-center gap-3 bg-green-50 border border-green-200 text-green-800 text-sm rounded-lg px-4 py-3 mb-6">
			<span class="font-semibold">Succès !</span>
			{{ message }}
		</div>
	{% endfor %}

	<div
		class="max-w-3xl mx-auto">

		<!-- En-tête recette -->
		<div class="mb-8">
			<h1 class="text-4xl font-bold text-[#3b3a30] mb-3">{{ recipe.name }}</h1>

			<div class="flex items-center gap-4 flex-wrap">
				<span class="inline-block bg-[#3b3a30] text-[#ffcc5c] text-xs font-semibold uppercase tracking-widest px-3 py-1.5 rounded-full">
					Créé le
					{{ recipe.createdAt|date('d/m/Y') }}
				</span>
				<span class="inline-flex items-center gap-1.5 text-sm font-semibold text-[#3b3a30]">
					⭐
					{{ recipe.average|number_format(2, '.', ',') }}
					/ 5
				</span>
			</div>
		</div>

		<!-- Infos principales -->
		<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">

			<div class="bg-[#3b3a30]/5 border border-[#3b3a30]/15 rounded-xl p-4 flex flex-col gap-1">
				<span class="text-xs font-semibold text-[#3b3a30]/50 uppercase tracking-wider">Temps</span>
				<span class="text-sm font-medium text-[#3b3a30]">
					{{ not recipe.time is same as(null) ? recipe.time ~ ' min' : 'Non renseigné' }}
				</span>
			</div>

			<div class="bg-[#3b3a30]/5 border border-[#3b3a30]/15 rounded-xl p-4 flex flex-col gap-1">
				<span class="text-xs font-semibold text-[#3b3a30]/50 uppercase tracking-wider">Personnes</span>
				<span class="text-sm font-medium text-[#3b3a30]">
					{{ not recipe.nbPeople is same as(null) ? recipe.nbPeople : 'Non renseigné' }}
				</span>
			</div>

			<div class="bg-[#3b3a30]/5 border border-[#3b3a30]/15 rounded-xl p-4 flex flex-col gap-1">
				<span class="text-xs font-semibold text-[#3b3a30]/50 uppercase tracking-wider">Difficulté</span>
				<span class="text-sm font-medium text-[#3b3a30]">
					{{ not recipe.difficulty is same as(null) ? recipe.difficulty : 'Non renseigné' }}
				</span>
			</div>

			<div class="bg-[#3b3a30]/5 border border-[#3b3a30]/15 rounded-xl p-4 flex flex-col gap-1">
				<span class="text-xs font-semibold text-[#3b3a30]/50 uppercase tracking-wider">Prix</span>
				<span class="text-sm font-medium text-[#3b3a30]">
					{{ not recipe.price is same as(null) ? recipe.price ~ ' €' : 'Non renseigné' }}
				</span>
			</div>

		</div>

		<!-- Description -->
		<div class="bg-white border border-[#3b3a30]/20 rounded-2xl p-6 mb-8">
			<h2 class="text-sm font-semibold text-[#3b3a30]/50 uppercase tracking-wider mb-3">Description</h2>
			<p class="text-sm text-black/70 leading-relaxed">
				{{ recipe.description|slice(0, 500) ~ '...' }}
			</p>
		</div>

		<!-- Ingrédients -->
		<div class="mb-8">
			<h2 class="text-lg font-bold text-[#3b3a30] mb-4">Ingrédients</h2>
			<div class="flex flex-wrap gap-2">
				{% for ingredient in recipe.ingredients %}
					<span class="inline-block px-4 py-1.5 rounded-full bg-[#ffcc5c]/20 border border-[#ffcc5c]/40 text-[#3b3a30] text-sm font-medium">
						{{ ingredient.name }}
					</span>
				{% endfor %}
			</div>
		</div>

		<!-- Formulaire de note -->
		<div class="bg-white border border-[#3b3a30]/20 rounded-2xl p-6">
			<h2 class="text-sm font-semibold text-[#3b3a30]/50 uppercase tracking-wider mb-4">Noter cette recette</h2>

			{{ form_start(form, {attr: {class: 'flex flex-col gap-4'}}) }}

			<div class="flex flex-col gap-1.5">
				{{ form_label(form.mark, null, {label_attr: {class: 'text-sm font-semibold text-[#3b3a30]'}}) }}
				{{ form_widget(form.mark, {attr: {class: 'w-full border border-[#3b3a30]/30 rounded-lg px-4 py-2.5 text-sm text-black focus:outline-none focus:border-[#ffcc5c] focus:ring-2 focus:ring-[#ffcc5c]/30 transition'}}) }}
				{{ form_errors(form.mark) }}
			</div>

			<div>
				{{ form_widget(form.submit, {attr: {class: 'px-6 py-2.5 rounded-full bg-[#3b3a30] text-white text-sm font-semibold hover:bg-[#ffcc5c] hover:text-[#3b3a30] transition shadow-md cursor-pointer'}}) }}
			</div>

			{{ form_end(form) }}
		</div>

	</div>

{% endblock %}
