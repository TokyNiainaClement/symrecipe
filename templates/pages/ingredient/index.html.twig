{% extends 'base.html.twig' %}

{% block title %}Symrecipe - Mes ingrédients
{% endblock %}

{% block body %}
	<div class="container mt-4">

		{% if not ingredients.items is same as([]) %}
			<h1>Mes ingrédients</h1>

			<a class="btn btn-dark btn-sm mt-3" href="{{ path('ingredient.new') }}">
				Créer un ingrédient
			</a>

			{# affiche un message de succes #}
			{% for message in app.flashes('success') %}
				<div class="alert alert-success mt-3">
					<strong>Succès!</strong>
					{{ message }}
				</div>
			{% endfor %}

			{# affiche le nombre total d'ingrédient #}
			<div class="count mt-4">
				Il y a
				{{ ingredients.getTotalItemCount }}
				ingrédients au total
			</div>

			{# Afficher la liste des ingrédients #}
			<table class="table table-bordered table-borderless">
				<thead>
					<tr>
						<th>Numréro</th>
						<th>Nom</th>
						<th>Prix</th>
						<th>Date de création</th>
						<th colspan="2">Action</th>
					</tr>
				</thead>
				<tbody>
					{% for ingredient in ingredients %}
						<tr class="table-active">
							<td>{{ ingredient.id }}</td>
							<td>{{ ingredient.name }}</td>
							<td>{{ ingredient.price }}</td>
							<td>{{ ingredient.createdAt|date('d/m/Y') }}</td>
							<td>
								<a class="btn btn-info btn-sm" href="#">
									Modifier
								</a>
							</td>
							<td>
								<a class="btn btn-danger btn-sm" href="{{ path('ingredient.delete', { id: ingredient.id }) }}">
									Supprimer
								</a>
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>

			{# affiche la navigation de pagination #}
			<div class="navigation d-flex justify-content-center">
				{{ knp_pagination_render(ingredients) }}
			</div>

		{% else %}
			<h4>Il n'y a pas d'ingrédients</h4>
		{% endif %}

	</div>
{% endblock %}
