{% extends 'base.html.twig' %}

{% block title %}
	Symrecipe - Accueil
{% endblock %}

{% block body %}

	<!-- Hero -->
	<div class="border-b border-[#3b3a30]/20 pb-10 mb-10">
		<h1 class="text-5xl font-bold text-[#3b3a30] mb-4 leading-tight">
			Bienvenue sur
			<span class="text-[#ffcc5c]">SymRecipe</span>
		</h1>
		<p class="text-lg text-black/70 max-w-2xl leading-relaxed mb-6">
			SymRecipe est une application qui va te permettre de créer des
						recettes base d'ingrédients que tu auras toi-même créer. Tu pourras partager tes
						recettes à la communauté du site, ou bien les garder en privées.
		</p>
		<hr class="border-[#3b3a30]/15 mb-6">
		<p class="text-black/60 mb-4">
			Pour commencer, rendez-vous sur la page d'inscription pour utiliser l'application.
		</p>
		<a href="{{ path('security.registration') }}" class="inline-block px-6 py-2.5 rounded-full bg-[#3b3a30] text-white text-sm font-semibold
						          hover:bg-[#ffcc5c] hover:text-[#3b3a30] transition shadow-md">
			Inscription
		</a>
	</div>

	<!-- Dernières recettes -->
	<div>
		<h5 class="text-xl font-semibold text-[#3b3a30] mb-6">
			Les trois recettes récemment publiées
		</h5>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
			{% for recipe in recipes %}
				<div
					class="rounded-xl border border-[#3b3a30]/20 overflow-visible shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200 flex flex-col">

					<!-- Badge avec image arrondie qui dépasse -->
					<div class="bg-[#3b3a30] px-4 pt-4 pb-3 flex items-center gap-4 rounded-t-xl relative">
						{% if vich_uploader_asset(recipe, 'imageFile') %}
							<img src="{{ vich_uploader_asset(recipe, 'imageFile') }}" alt="{{ recipe.name }}" class="w-16 h-16 rounded-full object-cover border-4 border-[#ffcc5c] shadow-lg shrink-0 -mt-6">
						{% else %}
							<span class="w-16 h-16 rounded-full bg-[#ffcc5c]/20 border-4 border-[#ffcc5c]/50 flex items-center justify-center text-2xl shrink-0 -mt-6">
								🍽️
							</span>
						{% endif %}
						<span class="text-[#ffcc5c] text-xs font-semibold uppercase tracking-widest">
							Recette n°{{ recipe.id }}
						</span>
					</div>

					<!-- Contenu -->
					<div class="bg-white p-5 flex flex-col gap-2 flex-1 rounded-b-xl">
						<h6 class="font-semibold text-base">
							<a href="{{ path('recipe.show', {id: recipe.id}) }}" class="text-[#3b3a30] hover:text-[#ffcc5c] transition">
								{{ recipe.name }}
							</a>
						</h6>
						<p class="text-sm text-black/60 leading-relaxed">
							{{ recipe.description|slice(0, 100) ~ '...' }}
						</p>
					</div>

				</div>
			{% endfor %}
		</div>
	</div>

{% endblock %}
