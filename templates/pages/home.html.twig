{% extends 'base.html.twig' %}

{% block title %}
	Symrecipe - Accueil
{% endblock %}

{% block body %}

	<!-- Hero -->
	<div class="border-b border-[#3b3a30]/20 pb-10 mb-10">
		<h1 class="text-5xl font-bold text-[#3b3a30] mb-4 leading-tight">
			Bienvenue sur <span class="text-[#ffcc5c]">SymRecipe</span>
		</h1>
		<p class="text-lg text-black/70 max-w-2xl leading-relaxed mb-6">
			SymRecipe est une application qui va te permettre de créer des
			recettes base d'ingrédients que tu auras toi-même créer. Tu pourras partager tes
			recettes à la communauté du site, ou bien les garder en privées.
		</p>
		<hr class="border-[#3b3a30]/15 mb-6">
		<p class="text-black/60 mb-4">
			Pour commencer, rendez-vous sur la page d'inscription pour utiliser l'application.
		</p>
		<a href="{{ path('security.registration') }}"
		   class="inline-block px-6 py-2.5 rounded-full bg-[#3b3a30] text-white text-sm font-semibold
		          hover:bg-[#ffcc5c] hover:text-[#3b3a30] transition shadow-md">
			Inscription
		</a>
	</div>

	<!-- Dernières recettes -->
	<div>
		<h5 class="text-xl font-semibold text-[#3b3a30] mb-6">
			Les trois dernières recettes publiées
		</h5>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
			{% for recipe in recipes %}
				<div class="rounded-xl border border-[#3b3a30]/20 overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200">

					<div class="bg-[#3b3a30] text-[#ffcc5c] text-xs font-semibold uppercase tracking-widest px-4 py-2.5">
						Recette n°{{ recipe.id }}
					</div>

					<div class="bg-white p-5">
						<h6 class="font-semibold text-base mb-2">
							<a href="{{ path('recipe.show', {id: recipe.id}) }}"
							   class="text-[#3b3a30] hover:text-[#ffcc5c] transition">
								{{ recipe.name }}
							</a>
						</h6>
						<p class="text-sm text-black/60 leading-relaxed">
							{{ recipe.description|slice(0, 100) ~ '...' }}
						</p>
					</div>

				</div>
			{% endfor %}
		</div>
	</div>

{% endblock %}