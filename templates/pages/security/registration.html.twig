{% extends 'base.html.twig' %}

{% block title %}SymRecipe - Inscription
{% endblock %}

{% block body %}

	<div class="max-w-md mx-auto">

		<h1 class="text-3xl font-bold text-[#3b3a30] mb-8">Inscription</h1>

		{{ form_start(form, {attr: {class: 'bg-white border border-[#3b3a30]/20 rounded-2xl shadow-sm p-8 flex flex-col gap-6'}}) }}

			<div class="flex flex-col gap-1.5">
				{{ form_label(form.fullName, null, {label_attr: {class: 'text-sm font-semibold text-[#3b3a30]'}}) }}
				{{ form_widget(form.fullName, {attr: {class: 'w-full border border-[#3b3a30]/30 rounded-lg px-4 py-2.5 text-sm text-black focus:outline-none focus:border-[#ffcc5c] focus:ring-2 focus:ring-[#ffcc5c]/30 transition'}}) }}
				{{ form_errors(form.fullName) }}
			</div>

			<div class="flex flex-col gap-1.5">
				{{ form_label(form.pseudo, null, {label_attr: {class: 'text-sm font-semibold text-[#3b3a30]'}}) }}
				{{ form_widget(form.pseudo, {attr: {class: 'w-full border border-[#3b3a30]/30 rounded-lg px-4 py-2.5 text-sm text-black focus:outline-none focus:border-[#ffcc5c] focus:ring-2 focus:ring-[#ffcc5c]/30 transition'}}) }}
				{{ form_errors(form.pseudo) }}
			</div>

			<div class="flex flex-col gap-1.5">
				{{ form_label(form.email, null, {label_attr: {class: 'text-sm font-semibold text-[#3b3a30]'}}) }}
				{{ form_widget(form.email, {attr: {class: 'w-full border border-[#3b3a30]/30 rounded-lg px-4 py-2.5 text-sm text-black focus:outline-none focus:border-[#ffcc5c] focus:ring-2 focus:ring-[#ffcc5c]/30 transition'}}) }}
				{{ form_errors(form.email) }}
			</div>

			<!-- plainPassword : first (mot de passe) -->
			<div class="flex flex-col gap-1.5">
				{{ form_label(form.plainPassword.first, null, {label_attr: {class: 'text-sm font-semibold text-[#3b3a30]'}}) }}
				{{ form_widget(form.plainPassword.first, {attr: {class: 'w-full border border-[#3b3a30]/30 rounded-lg px-4 py-2.5 text-sm text-black focus:outline-none focus:border-[#ffcc5c] focus:ring-2 focus:ring-[#ffcc5c]/30 transition'}}) }}
				{{ form_errors(form.plainPassword.first) }}
			</div>

			<!-- plainPassword : second (confirmation) -->
			<div class="flex flex-col gap-1.5">
				{{ form_label(form.plainPassword.second, null, {label_attr: {class: 'text-sm font-semibold text-[#3b3a30]'}}) }}
				{{ form_widget(form.plainPassword.second, {attr: {class: 'w-full border border-[#3b3a30]/30 rounded-lg px-4 py-2.5 text-sm text-black focus:outline-none focus:border-[#ffcc5c] focus:ring-2 focus:ring-[#ffcc5c]/30 transition'}}) }}
				{{ form_errors(form.plainPassword.second) }}
			</div>

			{{ form_errors(form.plainPassword) }}

			<div class="flex items-center justify-between pt-2">
				<div>
					{{ form_widget(form.submit, {attr: {class: 'px-6 py-2.5 rounded-full bg-[#3b3a30] text-white text-sm font-semibold hover:bg-[#ffcc5c] hover:text-[#3b3a30] transition shadow-md cursor-pointer'}}) }}
				</div>
				<a href="{{ path('security.login') }}"
				   class="text-sm text-black/50 hover:text-[#3b3a30] transition">
					Déjà un compte ?
				</a>
			</div>

		{{ form_end(form) }}

	</div>

{% endblock %}