					</a>
				</li>

				<li>
					<a href="{{ path('recipe.community') }}" class="text-sm font-medium px-3 py-2 rounded-md transition
																			   {% if app.current_route == 'recipe.community' %}
																			       text-[#ffcc5c] font-semibold underline underline-offset-4 decoration-[#ffcc5c]
																			   {% else %}
																			       text-white/75 hover:text-[#ffcc5c] hover:bg-[#ffcc5c]/10
																			   {% endif %}">
						Communauté
					</a>
				</li>

				{% if app.user %}
					<li>
						<a href="{{ path('ingredient.index') }}" class="text-sm font-medium px-3 py-2 rounded-md transition
