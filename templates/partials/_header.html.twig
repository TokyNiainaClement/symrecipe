																						   {% if app.current_route == 'recipe.index' or app.current_route == 'recipe.edit' or app.current_route == 'recipe.show' or app.current_route == 'recipe.new' %}
																						       text-[#ffcc5c] font-semibold underline underline-offset-4 decoration-[#ffcc5c]
